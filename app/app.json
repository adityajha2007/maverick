{
  "expo": {
    "name": "healthOS",
    "slug": "healthos",
    "scheme": "healthos",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.healthos.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "healthOS needs camera access to capture prescriptions and pain points."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.healthos.app"
    }
  }
}
