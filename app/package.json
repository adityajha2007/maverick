{
  "name": "healthos-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@op-engineering/op-sqlite": "^17.1.2",
    "babel-preset-expo": "^57.0.2",
    "expo": "~57.0.4",
    "expo-audio": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "^57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "^57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-status-bar": "~57.0.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-llm-mediapipe": "^0.5.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "better-sqlite3": "^12.11.1",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "test": "jest"
  },
  "private": true,
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "types": [
              "jest",
              "node",
              "better-sqlite3"
            ]
          }
        }
      ]
    }
  }
}
